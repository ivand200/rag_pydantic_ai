# Clerk configuration. Clerk remains external in iteration 1.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_PUBLIC_KEY=

# Browser-to-backend URL used by the Vite frontend.
VITE_API_BASE_URL=http://localhost:8000

# Comma-separated browser origins allowed to call the backend.
BACKEND_CORS_ORIGINS=http://localhost:5173

# Future RAG/OpenAI configuration. Documented for later iterations; unused by iteration 1.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-5.4-mini
