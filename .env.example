# Clerk configuration. Clerk remains external for auth and sessions.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_PUBLIC_KEY=

# Browser-to-backend URL used by the Vite frontend.
VITE_API_BASE_URL=http://localhost:8000

# Comma-separated browser origins allowed to call the backend.
BACKEND_CORS_ORIGINS=http://localhost:5173

# Local application database. Compose uses POSTGRES_* to initialize the service and
# DATABASE_URL for the backend/Alembic connection.
POSTGRES_DB=rag_service
POSTGRES_USER=rag_service
POSTGRES_PASSWORD=rag_service
DATABASE_URL=postgresql+psycopg://rag_service:rag_service@localhost:5432/rag_service
TEST_DATABASE_URL=postgresql+psycopg://rag_service:rag_service@localhost:5432/rag_service_test

# RAG/OpenAI configuration for ingestion, retrieval, and chat.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_TARGET_TOKENS=512
RAG_CHUNK_OVERLAP_TOKENS=80
RAG_QUERY_REWRITE_HISTORY_MESSAGES=6
RAG_ANSWER_HISTORY_MESSAGES=6
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_MIN_SIMILARITY=0.45
MAX_UPLOAD_BYTES=10485760
MAX_EXTRACTED_CHARS=500000

# S3-compatible object storage. Local Compose uses MinIO with these defaults.
MINIO_ROOT_USER=rag_service
MINIO_ROOT_PASSWORD=rag_service_password
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=rag-documents
OBJECT_STORAGE_ACCESS_KEY=rag_service
OBJECT_STORAGE_SECRET_KEY=rag_service_password
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SECURE=false
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Ingestion worker runtime settings.
INGESTION_WORKER_ID=local-worker-1
INGESTION_MAX_ATTEMPTS=3
INGESTION_BASE_RETRY_SECONDS=30
